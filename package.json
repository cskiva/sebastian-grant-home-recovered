{
	"name": "sebweb",
	"version": "1.0.0",
	"description": "A blank template to get started with Payload 3.0",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "cross-env NODE_OPTIONS=--no-deprecation next build",
		"dev": "concurrently \"./scripts/tunnel.sh\" \"payload generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next dev\"",
		"devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
		"generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
		"generate:types": "payload generate:types",
		"lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
		"payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
		"start": "cross-env NODE_OPTIONS=--no-deprecation next start",
		"seed:pages": "tsx scripts/seed-pages.ts",
		"capture-zoomify": "tsx scripts/capture-zoomify.ts",
		"capture-zoomify:force": "tsx scripts/capture-zoomify.ts --force",
		"capture-zoomify:watch": "tsx scripts/capture-zoomify.ts --watch"
	},
	"dependencies": {
		"@payloadcms/db-mongodb": "3.72.0",
		"@payloadcms/live-preview-react": "^3.72.0",
		"@payloadcms/next": "3.72.0",
		"@payloadcms/plugin-form-builder": "^3.72.0",
		"@payloadcms/plugin-nested-docs": "^3.72.0",
		"@payloadcms/plugin-redirects": "^3.72.0",
		"@payloadcms/plugin-search": "^3.72.0",
		"@payloadcms/plugin-seo": "^3.72.0",
		"@payloadcms/richtext-lexical": "3.72.0",
		"@payloadcms/storage-s3": "^3.72.0",
		"@phosphor-icons/react": "^2.1.10",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-progress": "^1.1.8",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tooltip": "^1.2.8",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"cross-env": "^7.0.3",
		"framer-motion": "^12.40.0",
		"gray-matter": "^4.0.3",
		"lodash": "^4.17.21",
		"lucide-react": "^0.376.0",
		"luxon": "^3.7.2",
		"moment": "^2.30.1",
		"netlify-cms-app": "^2.15.72",
		"next": "^15.4.10",
		"next-themes": "^0.4.6",
		"payload": "3.72.0",
		"prism-react-renderer": "^2.4.1",
		"radix-ui": "^1.4.3",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-hook-form": "^7.71.0",
		"react-share": "^5.2.2",
		"remark": "^15.0.1",
		"remark-html": "^16.0.1",
		"shadcn": "^4.8.0",
		"sharp": "0.32.6",
		"sonner": "^2.0.7",
		"tailwind-merge": "^2.3.0",
		"tailwindcss-animate": "^1.0.7",
		"tw-animate-css": "^1.4.0",
		"url-join": "^5.0.0"
	},
	"devDependencies": {
		"@next/eslint-plugin-next": "^16.1.1",
		"@types/lodash": "^4.17.23",
		"@types/luxon": "^3.7.1",
		"@types/node": "^20.11.25",
		"@types/react": "19.2.1",
		"@types/react-dom": "19.2.1",
		"autoprefixer": "^10.4.19",
		"concurrently": "^9.2.1",
		"dotenv": "^16.4.5",
		"eslint": "^9.39.2",
		"playwright": "^1.50.0",
		"postcss": "^8.4.38",
		"tailwindcss": "^3.4.3",
		"tsx": "^4.7.1",
		"typescript": "^5.4.2"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=18.19.0"
	}
}